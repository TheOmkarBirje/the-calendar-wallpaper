{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Calendar Wallpaper",
  "version": "0.1.1",
  "identifier": "com.omkarbirje.thecalendarwallpaper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "The Calendar Wallpaper",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "The Calendar Wallpaper",
    "shortDescription": "Auto-updates Windows desktop background on a schedule.",
    "longDescription": "The Calendar Wallpaper is a lightweight utility that runs in the background and automatically updates your Windows OS desktop wallpaper at a scheduled time each day based on a user-provided image URL.",
    "copyright": "Copyright 2026 The Calendar Wallpaper",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}